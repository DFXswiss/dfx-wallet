{
  "name": "dfx-wallet",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "postinstall": "patch-package && node node_modules/react-native-bare-kit/ios/link.mjs && cd node_modules/@tetherto/wdk-react-native-core && npm run build && cd ../../.. && npm run bundle:wdk",
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --check \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "e2e:maestro": "maestro test .maestro/",
    "e2e:maestro:ios": "maestro --platform ios test .maestro/",
    "e2e:maestro:android": "maestro --platform android test .maestro/",
    "prebuild": "expo prebuild --clean",
    "bundle:bitbox": "node scripts/bundle-bitbox-wasm.js",
    "bundle:wdk": "wdk-worklet-bundler generate --keep-artifacts",
    "check": "npm run typecheck && npm run lint && npm run format"
  },
